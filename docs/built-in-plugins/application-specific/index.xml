    <item>
      <title>Acmru</title>
      <link>https://anssi-fr.github.io/dfir-ogre-documentation/built-in-plugins/application-specific/acmru/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      
      <guid>https://anssi-fr.github.io/dfir-ogre-documentation/built-in-plugins/application-specific/acmru/</guid>
      <description>
        
        
        &lt;div class=&#34;hx:overflow-x-auto hx:mt-6 hx:flex hx:rounded-lg hx:border hx:py-2 hx:ltr:pr-4 hx:rtl:pl-4 hx:contrast-more:border-current hx:contrast-more:dark:border-current hx:border-purple-200 hx:bg-purple-100 hx:text-purple-900 hx:dark:border-purple-200/30 hx:dark:bg-purple-900/30 hx:dark:text-purple-200&#34;&gt;
  &lt;div class=&#34;hx:ltr:pl-3 hx:ltr:pr-2 hx:rtl:pr-3 hx:rtl:pl-2&#34;&gt;&lt;svg height=1.2em class=&#34;hx:inline-block hx:align-middle&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34; fill=&#34;none&#34; viewBox=&#34;0 0 24 24&#34; stroke-width=&#34;2&#34; stroke=&#34;currentColor&#34; aria-hidden=&#34;true&#34;&gt;&lt;path stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34; d=&#34;M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z&#34;/&gt;&lt;/svg&gt;&lt;/div&gt;

  &lt;div class=&#34;hx:w-full hx:min-w-0 hx:leading-7&#34;&gt;
    &lt;div class=&#34;hx:mt-6 hx:leading-7 hx:first:mt-0&#34;&gt;Data Type: &lt;strong&gt;acmru&lt;/strong&gt; &lt;br&gt;
Python Parser: &lt;strong&gt;RegAcMru&lt;/strong&gt;&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;h3&gt;Description&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;description&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#description&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;p&gt;Extracts Search Assistant  entries from &lt;code&gt;NTUser&lt;/code&gt; hive. .&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;Retrieves search queries entered in the Windows Search Assistant.&lt;/li&gt;
&lt;li&gt;Provides the chronological order of the queries via &lt;code&gt;order_index&lt;/code&gt;.&lt;/li&gt;
&lt;/ul&gt;
&lt;h3&gt;Timeline&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;timeline&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#timeline&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Timeline Field&lt;/th&gt;
					&lt;th&gt;Data Field&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Related User&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;key_security.owner_sid&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Description&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;search_request&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3&gt;Fields&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;fields&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#fields&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Output Name&lt;/th&gt;
					&lt;th&gt;Data Type&lt;/th&gt;
					&lt;th&gt;Qualifier&lt;/th&gt;
					&lt;th&gt;Description&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;search_request&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;String&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;search query entered in the Windows Search Assistant&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;order_index&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;String&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;position of the query in the MRU list (chronological order)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_path&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;String&lt;/td&gt;
					&lt;td&gt;KEY_PATH&lt;/td&gt;
					&lt;td&gt;full registry key name&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_modif_time&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;DateTime&lt;/td&gt;
					&lt;td&gt;DATE_MODIFICATION&lt;/td&gt;
					&lt;td&gt;last modification timestamp of the registry key&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;Object&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.owner_sid&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;String&lt;/td&gt;
					&lt;td&gt;USER_SID&lt;/td&gt;
					&lt;td&gt;SID of the user that owns the registry key&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.group_sid&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;String&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;SID of the group that owns the registry key&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.control_flags[]&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;Array[String]&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;security descriptor control flags for the key&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.dacl_ace&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;Object&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.dacl_ace.ace_type&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;String&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;type of ACE (e.g., allow, deny)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.dacl_ace.account_sid&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;String&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;SID of the account the ACE applies to&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.dacl_ace.ace_flags[]&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;Array[String]&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;ACE flags that modify inheritance or behavior&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;code&gt;key_security.dacl_ace.rights[]&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;Array[String]&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;permissions granted or denied by the ACE&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;

      </description>
    </item>
    
    <item>
      <title>Antifishing File</title>
